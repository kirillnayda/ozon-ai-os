# Несекретная конфигурация /etc/ozon-ai-developer/config.env
DEVELOPER_AGENT_DB_PATH=/var/lib/ozon-ai-developer/tasks.sqlite3
DEVELOPER_AGENT_WORKSPACE=/opt/ozon-ai-dev
DEVELOPER_AGENT_LOG_DIR=/var/log/ozon-ai-developer
DEVELOPER_AGENT_TASK_TIMEOUT=1800
DEVELOPER_AGENT_TEST_TIMEOUT=600
DEVELOPER_AGENT_MAX_ATTEMPTS=2
DEVELOPER_AGENT_BASE_BRANCH=main
CODEX_EXECUTABLE=codex
